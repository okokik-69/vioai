{
  "manifest_version": 3,
  "name": "VioScribe AI - Speech to Text",
  "version": "1.0",
  "description": "Chuyển đổi giọng nói thành văn bản thời gian thực và tóm tắt cuộc họp bằng AI.",
  "permissions": ["activeTab", "tabCapture", "storage", "microphone"],
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
