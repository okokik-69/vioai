rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: transcripts
    // Document ID: transcriptId
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - transcript: string (required)
    //   - summary: string (optional)
    //   - createdAt: timestamp (required)
    //   - userId: string (required)
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "kypro1557@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidTranscript(data) {
      return data.keys().hasAll(['id', 'name', 'transcript', 'createdAt', 'userId']) &&
             data.id is string && data.id.size() > 0 &&
             data.name is string && data.name.size() > 0 && data.name.size() < 500 &&
             data.transcript is string && data.transcript.size() > 0 &&
             data.userId == request.auth.uid &&
             (!('summary' in data) || data.summary == null || (data.summary is string && data.summary.size() < 20000)) &&
             data.createdAt is timestamp;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() > 0 &&
             (!('displayName' in data) || data.displayName == null || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('photoURL' in data) || data.photoURL == null || (data.photoURL is string && data.photoURL.size() < 500)) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /transcripts/{transcriptId} {
      allow read: if isAuthenticated() && (isDocOwner() || isAdmin());
      allow create: if isAuthenticated() && isValidTranscript(request.resource.data) && 
                      request.resource.data.id == transcriptId;
      allow update: if isAuthenticated() && (isDocOwner() || isAdmin()) && 
                      isValidTranscript(request.resource.data) && 
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.id == resource.data.id;
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                      request.resource.data.uid == resource.data.uid;
    }
  }
}
